# Source-based Dockerfile for local development. Slower than the release
# path (which uses a pre-built binary) but doesn't require GoReleaser.
FROM golang:1.24-alpine AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .

ARG VERSION=dev
ARG COMMIT=unknown
ARG BUILD_DATE=unknown

RUN CGO_ENABLED=0 go build \
    -ldflags "-s -w -X main.version=${VERSION} -X main.commit=${COMMIT} -X main.buildDate=${BUILD_DATE}" \
    -o /out/iceberg-sentry \
    ./cmd/iceberg-sentry

FROM alpine:3.24 AS certs
RUN apk --no-cache add ca-certificates

FROM scratch
COPY --from=certs /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
COPY --from=build /out/iceberg-sentry /usr/local/bin/iceberg-sentry
USER 65534:65534
ENV HOME=/tmp
WORKDIR /tmp
ENTRYPOINT ["/usr/local/bin/iceberg-sentry"]
CMD ["--help"]
